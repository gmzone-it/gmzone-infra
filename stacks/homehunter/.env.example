# =============================================================================
# HomeHunter — Runtime env (homelab)
# =============================================================================
# Copia in `.env` e popola i valori reali. NON committare `.env`.
#   cp .env.example .env && nano .env
#
# Generazione segreti:
#   openssl rand -hex 24        → POSTGRES_PASSWORD
#   openssl rand -base64 32     → NEXTAUTH_SECRET
# =============================================================================

# Tag dell'immagine da pullare da GHCR. 'latest' = ultimo build main.
# Per pinnare a un release: IMAGE_TAG=v0.1.0
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://homehunter.gmzone.it

# -----------------------------------------------------------------------------
# Email magic link — SMTP register.it (stesso account di gmzone-news-mailer)
# -----------------------------------------------------------------------------
# Host canonico (NON usare authsmtp.gmzone.it: cert TLS è per securemail.pro)
EMAIL_SERVER_HOST=authsmtp.securemail.pro
EMAIL_SERVER_PORT=465
EMAIL_SERVER_SECURE=true
EMAIL_SERVER_USER=admin@gmzone.it
EMAIL_SERVER_PASSWORD=
# Sender visualizzato. Default: stessa casella di auth.
# L'alias homehunter@gmzone.it esiste (creato in register.it) ma per il login
# si usa admin@gmzone.it per semplicità.
EMAIL_FROM=admin@gmzone.it

# -----------------------------------------------------------------------------
# OpenRouteService — https://openrouteservice.org/dev/#/signup (free tier)
# Usato dal prompt 6 (POI + isocrone). Lasciare vuoto è OK finché non serve.
# -----------------------------------------------------------------------------
ORS_API_KEY=

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_ISOCHRONES=true
