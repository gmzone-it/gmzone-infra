# =============================================================================
# homehunter — runtime secrets (sul homelab)
# =============================================================================
# Copia in `.env` (NON committare) e popola i valori reali.
#
# Generazione segreti:
#   POSTGRES_PASSWORD : openssl rand -hex 24
#   NEXTAUTH_SECRET   : openssl rand -base64 32
#
# Auth: solo Email magic link via SMTP register.it.
#   - User di auth: admin@gmzone.it (account reale che fa il SMTP AUTH)
#   - Mittente:     homehunter@gmzone.it (alias dedicato, da creare nel
#                   pannello register.it se non esiste già)
# =============================================================================

# Image tag da pullare. Default 'latest', ma per produzione conviene pinnare
# a un tag specifico (sha-xxxxxx o vX.Y.Z) per rollback rapidi.
IMAGE_TAG=latest

# --- Postgres ---------------------------------------------------------------
POSTGRES_PASSWORD=

# --- NextAuth ---------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://homehunter.gmzone.it

# --- Email magic link (SMTP register.it) -----------------------------------
# I default funzionano per register.it; basta popolare la password.
EMAIL_SERVER_HOST=authsmtp.securemail.pro
EMAIL_SERVER_PORT=465
EMAIL_SERVER_SECURE=true
EMAIL_SERVER_USER=admin@gmzone.it
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=homehunter@gmzone.it

# --- OpenRouteService -------------------------------------------------------
ORS_API_KEY=
